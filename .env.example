# Bootstrap config only — all API keys and secrets are managed via the admin UI (/admin.html)

PORT=3000
NODE_ENV=development

# Required — generate with: openssl rand -hex 32
SESSION_SECRET=

# Required — 64-char hex string for AES-256-GCM encryption of LinkedIn tokens.
# Without this every LinkedIn connect and publish attempt will fail at runtime.
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Required — password to access the /admin/settings page
ADMIN_PASSWORD=

# Optional — set only when frontend and backend are on different origins (separate subdomains).
# If both are served from the same Express server on the same domain, leave this unset.
# ALLOWED_ORIGIN=https://app.scouthook.com

# ---------------------------------------------------------------------------
# Redis — required in production for BullMQ scheduling and LinkedIn OAuth CSRF state.
# Without this, server restarts break in-flight OAuth flows and scheduled posts may not run.
# Upstash free tier (https://upstash.com) is sufficient for up to ~100 users.
# REDIS_URL=redis://default:xxx@your-redis-host:6379
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Database connection pool — tune for your hosting tier.
# Default is 30. Neon free tier supports up to 100 connections.
# PGPOOL_MAX=30
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Storage — local disk (dev) or Cloudflare R2 (production).
# Leave STORAGE_BACKEND=local for local development.
# ---------------------------------------------------------------------------
STORAGE_BACKEND=local

# Cloudflare R2 — production
# STORAGE_BACKEND=s3
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_BUCKET_NAME=scouthook-prod
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_KEY_PREFIX=prod
# R2_PUBLIC_URL=https://pub-<hash>.r2.dev   # Public bucket URL (custom domain or r2.dev) for direct thumbnail loading — optional but recommended in production

# ---------------------------------------------------------------------------
# Paddle Billing (required for subscription features)
# Get these from your Paddle dashboard: https://vendors.paddle.com/
# ---------------------------------------------------------------------------
# PADDLE_API_KEY=pdl_snd_xxx              # Server-side API key (secret)
# PADDLE_CLIENT_TOKEN=live_xxx            # Client-side token for Paddle.js (not secret)
# PADDLE_WEBHOOK_SECRET=pdl_ntfset_xxx    # Webhook endpoint secret (secret)
# PADDLE_PRICE_ID_PRO=pri_xxx             # Pro plan monthly price ID
# PADDLE_PRICE_ID_SOLO=pri_xxx            # Solo plan monthly price ID
# PADDLE_PRICE_ID_YEARLY=pri_xxx          # Pro plan yearly price ID
# PADDLE_CUSTOMER_PORTAL_URL=https://customer-portal.paddle.com/cpl_xxx  # Customer portal link (from Paddle dashboard)
# APP_URL=https://app.yoursite.com        # Used to construct the checkout success redirect URL

# ---------------------------------------------------------------------------
# Email (Resend) — transactional notifications
# Get your API key at https://resend.com/api-keys
# ---------------------------------------------------------------------------
# RESEND_API_KEY=re_xxx                   # Resend API key (secret)
# EMAIL_FROM=ScoutHook <noreply@scouthook.com>  # Verified sender address in Resend

# ---------------------------------------------------------------------------
# Mailerlite — marketing list sync (free & pro segments)
# API key: Mailerlite → Integrations → API
# Group IDs: Mailerlite → Subscribers → Groups → click a group → copy ID from URL
# ---------------------------------------------------------------------------
# MAILERLITE_API_KEY=               # API key (secret)
# MAILERLITE_GROUP_FREE=            # Group ID for free users
# MAILERLITE_GROUP_PRO=             # Group ID for pro subscribers

# ---------------------------------------------------------------------------
# Pexels — stock photo search in the design editor (free)
# Get your API key at https://www.pexels.com/api/
# ---------------------------------------------------------------------------
# PEXELS_API_KEY=

# ---------------------------------------------------------------------------
# Placid — AI image generation (Pro feature)
# Get your API key and template UUID from https://placid.app
# PLACID_LAYER_HEADLINE and PLACID_LAYER_SUBTEXT must match the layer names
# in your Placid template (defaults: "headline" and "subtext").
# ---------------------------------------------------------------------------
# PLACID_API_KEY=                         # Placid API key (secret)
# PLACID_TEMPLATE_ID=                     # Template UUID for AI-generated post images
# PLACID_LAYER_HEADLINE=headline          # Layer name for headline text
# PLACID_LAYER_SUBTEXT=subtext            # Layer name for subtext

# ---------------------------------------------------------------------------
# Feedback notifications
# When set, an email is sent to this address whenever a user submits feedback.
# ---------------------------------------------------------------------------
# ADMIN_EMAIL=you@example.com
