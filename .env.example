# Bootstrap config only — all API keys and secrets are managed via the admin UI (/admin.html)

PORT=3000
NODE_ENV=development

# Password to access the /admin/settings page
ADMIN_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Storage — local disk (default) or Amazon S3
# Set STORAGE_BACKEND=s3 and fill in the S3 block to enable cloud storage.
# Leave STORAGE_BACKEND=local (or unset) for local development.
# ---------------------------------------------------------------------------
STORAGE_BACKEND=local

# S3 — development bucket
# STORAGE_BACKEND=s3
# S3_BUCKET_NAME=scout-hook-dev
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_KEY_PREFIX=           # optional — e.g. "dev/" to isolate within a shared bucket

# S3 — production bucket (set in your hosting provider's env, not here)
# S3_BUCKET_NAME=scout-hook-prod
# S3_REGION=us-east-1

# S3_ENDPOINT=             # optional — custom endpoint for MinIO / LocalStack

# ---------------------------------------------------------------------------
# Paddle Billing (required for subscription features)
# Get these from your Paddle dashboard: https://vendors.paddle.com/
# ---------------------------------------------------------------------------
# PADDLE_API_KEY=pdl_snd_xxx              # Server-side API key (secret)
# PADDLE_CLIENT_TOKEN=live_xxx            # Client-side token for Paddle.js (not secret)
# PADDLE_WEBHOOK_SECRET=pdl_ntfset_xxx    # Webhook endpoint secret (secret)
# PADDLE_PRICE_ID_MONTHLY=pri_xxx         # Pro plan monthly price ID
# PADDLE_PRICE_ID_YEARLY=pri_xxx          # Pro plan yearly price ID
# APP_URL=https://app.yoursite.com        # Used to construct the checkout success redirect URL
